{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "REACT EEG",
  "version": "19.0.0",
  "identifier": "com.reacteeg.desktop",
  "build": {
    "frontendDist": "../dist-tauri",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "REACT EEG",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "REACT EEG, LLC",
    "category": "Medical",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
