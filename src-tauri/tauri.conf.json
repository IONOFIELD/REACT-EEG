{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "REACT EEG",
  "version": "../package.json",
  "identifier": "com.reacteeg.desktop",
  "build": {
    "frontendDist": "../dist-tauri",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "REACT EEG",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "REACT EEG, LLC",
    "category": "Medical",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/brain.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/IONOFIELD/REACT-EEG/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGQTAzRUJGNTIwOEVBMTAKUldRUTZnaFN2ejZnYjZDYWUwMmtYck5hem5GQkNSTndLY0l0OW0yZDZlWEwyTEdaZjc4Z1QxK0kK"
    }
  }
}
